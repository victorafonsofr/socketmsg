import socket

server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
PORT = 4411

try: 
    server.bind(("127.0.0.1", PORT))
    server.listen(5) #no max 5 conexões simultaneas
    print(f'<Listening on {PORT}>\n')

    socket_cli, addr = server.accept()

    print("Received from:\nip: "+ addr[0])
    
    while True:

        data = socket_cli.recv(1024).decode()
        print(f"mensagem recebida: {data}")
        
        if data == "12b3\n":
            socket_cli.send((b'Secret message: congrats u got it!\n'))
            break

        
    server.close()


except Exception as err:
    print("erro: ",err)
    server.close()
